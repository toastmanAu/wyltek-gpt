#!/usr/bin/env python3
"""CLI bridge between local-chatbot converter system and qwen3-asr-worker.

The converter system calls this as a subprocess with fixed argv slots.
We POST the audio file path to the worker HTTP API and write the
returned text to the requested output path.

Usage:
    qwen3-asr-transcribe --input /path/to/audio.mp3 --output /path/to/out.txt [--model 1.7B]
"""
from __future__ import annotations

import argparse
import json
import sys
import urllib.request
from pathlib import Path

WORKER_URL = "http://127.0.0.1:9096"


def main() -> int:
    parser = argparse.ArgumentParser(description="Qwen3-ASR transcription client")
    parser.add_argument("--input", required=True, help="Input audio file path")
    parser.add_argument("--output", required=True, help="Output text file path")
    parser.add_argument("--model", default="1.7B", help="Model size ( informational — worker decides)")
    args = parser.parse_args()

    input_path = Path(args.input)
    if not input_path.exists():
        print(f"error: input file not found: {args.input}", file=sys.stderr)
        return 1

    # Health-check worker first
    try:
        urllib.request.urlopen(f"{WORKER_URL}/status", timeout=5.0).read()
    except Exception as exc:
        print(
            f"error: qwen3-asr-worker not responding at {WORKER_URL} ({exc}).\n"
            f"       Start it with: systemctl --user start qwen3-asr-worker.service",
            file=sys.stderr,
        )
        return 1

    # Send transcription request
    req_body = json.dumps({
        "file_path": str(input_path.resolve()),
        "language": None,
    }).encode("utf-8")

    req = urllib.request.Request(
        f"{WORKER_URL}/transcribe",
        data=req_body,
        headers={"Content-Type": "application/json"},
        method="POST",
    )

    try:
        with urllib.request.urlopen(req, timeout=600.0) as resp:
            data = json.loads(resp.read().decode("utf-8"))
    except urllib.error.HTTPError as exc:
        body = exc.read().decode("utf-8", errors="ignore")[-500:]
        print(f"error: worker returned {exc.code}: {body}", file=sys.stderr)
        return 1
    except Exception as exc:
        print(f"error: failed to contact worker: {exc}", file=sys.stderr)
        return 1

    text = data.get("text", "")
    output_path = Path(args.output)
    output_path.write_text(text, encoding="utf-8")
    print(f"Transcribed in {data.get('elapsed_s', '?')}s → {output_path}")
    return 0


if __name__ == "__main__":
    sys.exit(main())
